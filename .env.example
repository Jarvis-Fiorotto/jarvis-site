# Public site configuration
NEXT_PUBLIC_SITE_URL=https://example.com

# Private auth configuration
AUTH_SECRET=change-me
SCHEDULE_USERS_JSON=[{"username":"Danilo","name":"Danilo","passwordHash":"sha256-hash-here"}]

# Runtime data store: keeps CAE/CrewCare/status data outside Git/deploys.
NEXT_PUBLIC_SUPABASE_URL=https://project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key-for-server-side-sync-only
SUPABASE_DOCUMENTS_TABLE=jarvis_site_documents
SUPABASE_SYNC_RUNS_TABLE=jarvis_site_sync_runs

# Commute alerts: free routing mode uses OSRM, no Google billing, no real-time traffic.
COMMUTE_ORIGIN_LABEL=Casa
COMMUTE_ORIGIN_LAT=-23.000000
COMMUTE_ORIGIN_LON=-47.000000
COMMUTE_VCP_DESTINATION_LABEL=Aeroporto de Viracopos
COMMUTE_VCP_LAT=-23.007400
COMMUTE_VCP_LON=-47.134500
COMMUTE_AIRPORT_WALK_BUFFER_MINUTES=20
COMMUTE_FREE_API_TRAFFIC_BUFFER_MINUTES=15
COMMUTE_LOOKAHEAD_HOURS=48
COMMUTE_REMIND_HOURS_BEFORE=24,4,2
